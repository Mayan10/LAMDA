PORT=5001
UPDATE_INTERVAL_MINUTES=30

# The backend now uses the scrapers directly in-process by default.
# Set this to true only if you want api_server.py to call separately running scraper services.
SCRAPER_HTTP_ENABLED=false

# Optional but recommended for richer live data
SERPAPI_API_KEY=
OPENWEATHERMAP_API_KEY=

# Optional LLM settings for intelligence_processor.py
# Supported values: gemini, heuristic
INTELLIGENCE_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional overrides for runtime files
# DB_PATH=supply_chain_graph.db
# GRAPH_STATE_FILE=graph_state.json
# RISK_VECTORS_FILE=risk_vectors_output.json
